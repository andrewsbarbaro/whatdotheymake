# Copy to .env (this file is gitignored)

# Optional server bindings
NUXT_D1_DATABASE=

# Required: URL of your LLM endpoint (LiteLLM proxy or Anthropic-compatible endpoint)
NUXT_LLM_BASE_URL=

# Required for content moderation (POST /api/submit, /api/edit)
NUXT_LLM_AUTOMOD_API_KEY=

# Required for salary scoring (POST /api/submit)
NUXT_LLM_SALARY_API_KEY=
# Optional fallback: direct Anthropic API key used only if your LLM proxy is unavailable
NUXT_LLM_FAILOVER_API_KEY=

# Optional — model + request tuning (defaults shown)
NUXT_ANTHROPIC_BASE_URL=https://api.anthropic.com
NUXT_ANTHROPIC_MODEL=claude-haiku-4-5
NUXT_ANTHROPIC_MODERATION_MAX_TOKENS=300
NUXT_ANTHROPIC_MODERATION_TIMEOUT_MS=8000
NUXT_ANTHROPIC_SALARY_MODEL=
NUXT_ANTHROPIC_SALARY_MAX_TOKENS=350
NUXT_ANTHROPIC_SALARY_TIMEOUT_MS=8000

# Optional — utility behavior knobs
NUXT_CURRENCY_RATES_TTL_MS=1800000
NUXT_CURRENCY_FETCH_TIMEOUT_MS=5000
NUXT_CURRENCY_PROVIDER_URL=https://open.er-api.com/v6/latest/USD
NUXT_MAP_GEOCODE_CACHE_TTL_MS=2592000000
NUXT_MAP_GEOCODE_CONCURRENCY=4
NUXT_MAP_GEOCODE_USER_AGENT=whatdotheymake-map/1.0 (opensource@whatdotheymake.com)
NUXT_SALARY_ESTIMATE_CACHE_TTL_MS=86400000

# Public runtime
NUXT_PUBLIC_SITE_URL=https://whatdotheymake.com
